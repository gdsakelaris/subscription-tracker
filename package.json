{
    "name": "subscription-tracker",
    "version": "1.0.0",
    "description": "A desktop subscription tracker application",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build-win": "electron-builder --win",
        "build": "electron-builder",
        "dist": "electron-builder --publish=never"
    },
    "keywords": [
        "subscription",
        "tracker",
        "desktop",
        "electron"
    ],
    "author": "Your Name",
    "license": "MIT",
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.0.0"
    },
    "build": {
        "appId": "com.yourname.subscriptiontracker",
        "productName": "Subscription Tracker",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "index.html",
            "package.json"
        ],
        "win": {
            "target": "nsis",
            "icon": "icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        }
    }
}